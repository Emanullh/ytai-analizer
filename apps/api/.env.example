PORT=3001
TRANSCRIPT_LANG=

LOCAL_ASR_ENABLED=true
LOCAL_ASR_MODEL=large-v3-turbo
LOCAL_ASR_COMPUTE_TYPE=auto
LOCAL_ASR_LANGUAGE=auto
LOCAL_ASR_BEAM_SIZE=5
LOCAL_ASR_MAX_CONCURRENCY=1
